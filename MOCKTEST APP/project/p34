CREATE DATABASE college_management;

USE college_management;

CREATE TABLE students (
    student_id INT PRIMARY KEY,
    name VARCHAR(100),
    age INT,
    course VARCHAR(100)
);

CREATE TABLE fees (
    student_id INT,
    fee_due INT,
    FOREIGN KEY (student_id) REFERENCES students(student_id)
);

CREATE TABLE results (
    student_id INT,
    subject VARCHAR(100),
    grade VARCHAR(5),
    FOREIGN KEY (student_id) REFERENCES students(student_id)
);


import tkinter as tk
from tkinter import messagebox

class Student:
    def __init__(self, student_id, name, age, course):
        self.student_id = student_id
        self.name = name
        self.age = age
        self.course = course
        self.fee_due = 0
        self.results = {}

    def add_fee_due(self, amount):
        self.fee_due += amount

    def pay_fee(self, amount):
        if amount > self.fee_due:
            messagebox.showerror("Error", "Amount exceeds due fee. Please pay the exact or less amount.")
        else:
            self.fee_due -= amount

    def add_result(self, subject, grade):
        self.results[subject] = grade

    def get_details(self):
        return {
            "ID": self.student_id,
            "Name": self.name,
            "Age": self.age,
            "Course": self.course,
            "Fee Due": self.fee_due,
            "Results": self.results
        }

class College:
    def __init__(self):
        self.students = {}

    def add_student(self, student):
        self.students[student.student_id] = student

    def remove_student(self, student_id):
        if student_id in self.students:
            del self.students[student_id]
        else:
            messagebox.showerror("Error", "Student ID not found.")

    def get_student(self, student_id):
        if student_id in self.students:
            return self.students[student_id].get_details()
        else:
            return "Student ID not found."

    def update_fee_due(self, student_id, amount):
        if student_id in self.students:
            self.students[student_id].add_fee_due(amount)
        else:
            messagebox.showerror("Error", "Student ID not found.")

    def pay_fee(self, student_id, amount):
        if student_id in self.students:
            self.students[student_id].pay_fee(amount)
        else:
            messagebox.showerror("Error", "Student ID not found.")

    def add_result(self, student_id, subject, grade):
        if student_id in self.students:
            self.students[student_id].add_result(subject, grade)
        else:
            messagebox.showerror("Error", "Student ID not found.")

class App:
    def __init__(self, root, college):
        self.college = college
        self.root = root
        self.root.title("College Management System")

        self.student_id_label = tk.Label(root, text="Student ID")
        self.student_id_label.grid(row=0, column=0)
        self.student_id_entry = tk.Entry(root)
        self.student_id_entry.grid(row=0, column=1)

        self.name_label = tk.Label(root, text="Name")
        self.name_label.grid(row=1, column=0)
        self.name_entry = tk.Entry(root)
        self.name_entry.grid(row=1, column=1)

        self.age_label = tk.Label(root, text="Age")
        self.age_label.grid(row=2, column=0)
        self.age_entry = tk.Entry(root)
        self.age_entry.grid(row=2, column=1)

        self.course_label = tk.Label(root, text="Course")
        self.course_label.grid(row=3, column=0)
        self.course_entry = tk.Entry(root)
        self.course_entry.grid(row=3, column=1)

        self.fee_due_label = tk.Label(root, text="Fee Due")
        self.fee_due_label.grid(row=4, column=0)
        self.fee_due_entry = tk.Entry(root)
        self.fee_due_entry.grid(row=4, column=1)

        self.subject_label = tk.Label(root, text="Subject")
        self.subject_label.grid(row=5, column=0)
        self.subject_entry = tk.Entry(root)
        self.subject_entry.grid(row=5, column=1)

        self.grade_label = tk.Label(root, text="Grade")
        self.grade_label.grid(row=6, column=0)
        self.grade_entry = tk.Entry(root)
        self.grade_entry.grid(row=6, column=1)

        self.add_student_button = tk.Button(root, text="Add Student", command=self.add_student)
        self.add_student_button.grid(row=7, column=0)

        self.remove_student_button = tk.Button(root, text="Remove Student", command=self.remove_student)
        self.remove_student_button.grid(row=7, column=1)

        self.update_fee_button = tk.Button(root, text="Update Fee", command=self.update_fee)
        self.update_fee_button.grid(row=8, column=0)

        self.pay_fee_button = tk.Button(root, text="Pay Fee", command=self.pay_fee)
        self.pay_fee_button.grid(row=8, column=1)

        self.add_result_button = tk.Button(root, text="Add Result", command=self.add_result)
        self.add_result_button.grid(row=9, column=0)

        self.get_details_button = tk.Button(root, text="Get Details", command=self.get_details)
        self.get_details_button.grid(row=9, column=1)

        self.result_label = tk.Label(root, text="")
        self.result_label.grid(row=10, columnspan=2)

    def add_student(self):
        student_id = int(self.student_id_entry.get())
        name = self.name_entry.get()
        age = int(self.age_entry.get())
        course = self.course_entry.get()
        student = Student(student_id, name, age, course)
        self.college.add_student(student)
        messagebox.showinfo("Success", "Student added successfully")

    def remove_student(self):
        student_id = int(self.student_id_entry.get())
        self.college.remove_student(student_id)
        messagebox.showinfo("Success", "Student removed successfully")

    def update_fee(self):
        student_id = int(self.student_id_entry.get())
        amount = int(self.fee_due_entry.get())
        self.college.update_fee_due(student_id, amount)
        messagebox.showinfo("Success", "Fee updated successfully")

    def pay_fee(self):
        student_id = int(self.student_id_entry.get())
        amount = int(self.fee_due_entry.get())
        self.college.pay_fee(student_id, amount)
        messagebox.showinfo("Success", "Fee paid successfully")

    def add_result(self):
        student_id = int(self.student_id_entry.get())
        subject = self.subject_entry.get()
        grade = self.grade_entry.get()
        self.college.add_result(student_id, subject, grade)
        messagebox.showinfo("Success", "Result added successfully")

    def get_details(self):
        student_id = int(self.student_id_entry.get())
        details = self.college.get_student(student_id)
        self.result_label.config(text=str(details))

if __name__ == "__main__":
    root = tk.Tk()
    college = College()
    app = App(root, college)
    root.mainloop()
